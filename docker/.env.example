# VIATOR — environment variables
#
# Copy to `.env` and fill in. This file holds bootstrap-only secrets that
# need to exist before Postgres + the platform_config table do. All other
# operational tunables (SMTP credentials, concurrency limits, retention
# windows, fanout timeouts) live in `platform_config` and are edited from
# Admin → Configuration in the UI.
#
# Generate strong values with: openssl rand -base64 32

# ────────────────────────────── Image version ──────────────────────────────
# Pin to a release tag for reproducible deploys, or `latest` to track main.
# Used by `docker compose pull|up` to select the image.
#
# Both forms are published — the `v`-prefixed git tag and the bare semver:
#   VIATOR_VERSION=v0.1.3   (matches the git tag, more obvious to read)
#   VIATOR_VERSION=0.1.3    (Docker convention)
#   VIATOR_VERSION=latest   (rolling main)
# Pre-v0.1.4 only the bare-semver form was published. If you're pinning to
# v0.1.0/v0.1.1/v0.1.2/v0.1.3, drop the `v`.
VIATOR_VERSION=latest

# ──────────────────────────────── Postgres ─────────────────────────────────
POSTGRES_USER=viator
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=viator

# ────────────────────────────── JWT auth ──────────────────────────────────
# 64+ random bytes. Rotating this invalidates every issued JWT (everyone
# logs out). Don't rotate without a planned operator notification.
JWT_SECRET=change-me-please-use-openssl-rand-base64-64
# Set to `true` once HTTPS is wired (step 9 of INSTALL.md). Leave false on
# plain HTTP or browsers won't accept the cookie.
JWT_COOKIE_SECURE=false

# ─────────────────────── First-platform-admin bootstrap ────────────────────
# Set ONCE on first deploy. Hit POST /api/auth/bootstrap-platform-user with
# this token to create the first platform_admin (see INSTALL.md §8).
# Then set BOOTSTRAP_TOKEN= (empty) and `docker compose restart web`.
BOOTSTRAP_TOKEN=change-me-please-one-time-only

# ──────────────────────────── Public base URL ──────────────────────────────
# Used to build absolute URLs in magic-link emails (registration confirm,
# password reset). Must match the public hostname users will click through.
PUBLIC_BASE_URL=http://localhost

# ─────────────────────────────── Upload limits ─────────────────────────────
MAX_UPLOAD_MB=2048

# ──────────────────────────────── OTP build resources ─────────────────────
# OTP graph build is RAM-bound. With OTP_BUILD_PHASES=two_phase (default),
# peak heap is much lower than legacy --build because the OSM parse and the
# transit overlay run in separate JVMs. Recommended sizes:
#   Île-de-France only:  OTP_BUILD_HEAP=8g    OTP_BUILD_MEM_LIMIT=12g
#   France-wide:         OTP_BUILD_HEAP=24g   OTP_BUILD_MEM_LIMIT=28g
OTP_BUILD_HEAP=8g

# Build pipeline: 'two_phase' (default) or 'one_shot' (legacy --build, debug
# only — needs ~30% more heap for the same input). Stay with two_phase unless
# you're chasing a regression that only reproduces in single-JVM mode.
OTP_BUILD_PHASES=two_phase

# Hard cgroup memory cap on the otp-build container. Should be `-Xmx` plus
# ~4 GB of native headroom (Direct buffers, metaspace, threads, GC). Setting
# this is what turns "the host slowly swaps for an hour" into a fast OOMKilled
# signal we can see in `docker compose logs`.
OTP_BUILD_MEM_LIMIT=12g

# ────────────────────────────── Rebuild debounce ───────────────────────────
# Worker coalesces upload-triggered rebuilds within this window (seconds).
# Default 30 min; lower for testing, higher for noisy operators.
DEBOUNCE_SECONDS=1800

# ───────────────── Phase-1 transitional — basic-auth upload UI ─────────────
# The upload UI on `/` (single-OTP Phase-1 surface) is still wired and uses
# HTTP basic auth. Leave both empty if you only use the Phase-2 admin UI
# and don't want the Phase-1 routes accessible at all.
ADMIN_USER=
ADMIN_PASSWORD=

# ────────────────────────────── Structured logging ────────────────────────
# Production containers emit JSON-per-line to stdout (ingestible by Loki,
# CloudWatch, ELK, etc.). Switch to LOG_FORMAT=console for human-readable
# colored output during local dev.
LOG_LEVEL=INFO
LOG_FORMAT=json

# ───────────────────────────── Docker socket GID ───────────────────────────
# The worker container runs as a non-root user (UID 1000) so it can't read
# /var/run/docker.sock by default. The host's docker group GID is
# distribution-dependent; supplying it here makes compose attach the worker
# user to that supplementary group.
#
# Find the host docker group GID:
#   getent group docker | cut -d: -f3
#
# Common defaults: 999 (Debian/Ubuntu apt-installed docker.io / docker-ce),
# 998 (some RHEL variants), 200 (Docker Desktop on macOS — different model,
# only matters if you build images locally on Mac and don't deploy from
# there). If unsure, run the getent command above on the deploy host.
DOCKER_GID=999
