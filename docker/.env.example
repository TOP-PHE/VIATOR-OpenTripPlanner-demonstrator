# Copy to .env and edit before `docker compose up`.

# ---- Postgres ----
POSTGRES_USER=otp
POSTGRES_PASSWORD=change-me
POSTGRES_DB=otp

# ---- Web admin (basic auth on the upload UI) ----
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# ---- Upload limits ----
MAX_UPLOAD_MB=2048

# ---- OTP heap sizes ----
OTP_BUILD_HEAP=12g
OTP_SERVE_HEAP=16g

# ---- Rebuild debounce (seconds) ----
DEBOUNCE_SECONDS=1800
